{
  "name": "subscription-bingo-backend",
  "version": "1.0.0",
  "description": "Backend API for subscription bingo game",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
